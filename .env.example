BEEHIIV_API_KEY=         # Your Beehiiv API key — Settings > API
BEEHIIV_PUBLICATION_ID=  # pub_xxxxxxxxxxxxxxxx — found in Settings > Publication
NOTION_API_KEY=          # secret_xxxxxxx — from notion.so/my-integrations
NOTION_SUBSCRIBERS_DB_ID= # ID of Notion database for subscribers (run setup command to create)
NOTION_POSTS_DB_ID=       # ID of Notion database for posts (run setup command to create)
SYNC_INTERVAL_HOURS=6    # How often to sync when running in scheduler mode
